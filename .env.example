# Database
DATABASE_URL=postgresql://xero:xero_password@db:5432/xero_db
POSTGRES_DB=xero_db
POSTGRES_USER=xero
POSTGRES_PASSWORD=xero_password

# JWT（必ず変更すること）
JWT_SECRET=replace-with-strong-random-secret-min-32chars

# AES暗号化キー（招待リンク用、base64 32バイト）
AES_SECRET_KEY=replace-with-base64-encoded-32-byte-key

# サーバー設定
NODE_ENV=development
PORT=8000
CORS_ORIGIN=http://localhost:5173

# フロントエンド
VITE_API_BASE=http://localhost:8000
